#!/bin/bash
VENDOR=$1 # Capture 'nvidia' or 'amd' from the plugin
OS_TYPE=$2
LOG_DIR=$3
DATA_DIR=$4
SUPERGFX_TRIG=0
#PRIMARY_USER=$(echo "$LOG_DIR" | cut -d/ -f3)
PRIMARY_USER=$(ps -o user= -C steam | head -n 1 | xargs)
[ -z "$PRIMARY_USER" ] && PRIMARY_USER="deck"
mkdir -p "$DATA_DIR/configs"
exec > "$LOG_DIR/xgmobile_manager_enable_${VENDOR}.log" 2>&1

echo "--- XG Mobile Enable ($VENDOR) Started at $(date) ---"

# Hardware Lock Check
CONNECTED=$(cat /sys/devices/platform/asus-nb-wmi/egpu_connected || echo "0")
if [ "$CONNECTED" -eq 0 ]; then
  echo "ERROR: XG Mobile not locked."
  exit 1
fi

if [[ "$OS_TYPE" == "steamos" || "$OS_TYPE" == *"cachyos"* ]];  then
  # check if its NVIDIA and if so, check for drivers before continuing
  if [ "$VENDOR" == "nvidia" ]; then
    # Check if the kernel module is actually loadable
    if ! modinfo nvidia >/dev/null 2>&1; then
      echo "ERROR: NVIDIA Driver is not installed. Please run the Install NVIDIA drivers button, or select AMD."
      exit 2
    fi
    if [ ! -f "$DATA_DIR/configs_backup/nvidia_icd.json" ] && [ ! -f "/usr/share/vulkan/icd.d/nvidia_icd.json" ]; then
      if [ -f "/home/deck/xgmobile_configs_backup/nvidia_icd.json" ]; then
        echo "CRITICAL ERROR: NVIDIA Vulkan configs detected in old folder location due to v0.2.0 migration."
        echo "Please use the 'Install NVIDIA Drivers' button in the plugin to regenerate them."
        exit 3
      else
        echo "CRITICAL ERROR: NVIDIA Vulkan configs missing due to v0.2.0 migration."
        echo "Please use the 'Install NVIDIA Drivers' button in the plugin to regenerate them."
        exit 4
      fi
    fi
  fi

  # SELF-HEALING BLOCK (Replaces repair-services)
  echo "Verifying system services..."
  REPO_ROOT=$(readlink -f "$(dirname "$(readlink -f "$0")")/..")
  NEEDS_REPAIR=0

  # Check if global commands are missing
  [ ! -L /usr/local/bin/egpu-enable ] && NEEDS_REPAIR=1

  # Check if NVIDIA services/sleep scripts are missing
  if [ "$VENDOR" == "nvidia" ]; then
    [ ! -f /etc/systemd/system/nvidia-suspend.service ] && NEEDS_REPAIR=1
  fi

  if [ "$NEEDS_REPAIR" -eq 1 ]; then
    echo "System files missing. Initiating self-repair..."
    steamos-readonly disable
  
    # Restore global terminal commands
    ln -sf "$REPO_ROOT/bin/egpu-enable" /usr/local/bin/egpu-enable
    ln -sf "$REPO_ROOT/bin/egpu-eject" /usr/local/bin/egpu-eject
    chmod +x "$REPO_ROOT/bin/egpu-enable" "$REPO_ROOT/bin/egpu-eject"
  
    # Copy background services
    cp "$REPO_ROOT/assets/services/"*.service /etc/systemd/system/ 2>/dev/null || true
  
    if [ "$VENDOR" == "nvidia" ]; then
      echo "Restoring NVIDIA sleep services..."
      systemctl daemon-reload
      systemctl enable nvidia-persistenced nvidia-powerd nvidia-suspend.service nvidia-hibernate.service nvidia-resume.service 2>/dev/null
      systemctl start nvidia-persistenced 2>/dev/null
    else
      systemctl daemon-reload
    fi
    steamos-readonly enable
    echo "Self-repair complete."
  fi
fi

if [ -L /usr/lib/systemd/system-sleep/egpu-resume-fix ] || [ -f /usr/lib/systemd/system-sleep/egpu-resume-fix ]; then
  echo "Purging obsolete legacy egpu-resume-fix..."
  steamos-readonly disable
  rm -f /usr/lib/systemd/system-sleep/egpu-resume-fix
  rm -f /etc/systemd/system/egpu-resume-fix.service
  rm -f /etc/systemd/system/egpu-boot-guardian.service
  steamos-readonly enable
fi

if systemctl is-active --quiet supergfxd.service; then 
  echo "Supergfxd Detected. Stopping supergfxd to avoid panic during switch..."
  systemctl stop supergfxd.service 2>/dev/null || true
  SUPERGFX_TRIG=1
fi

# Used for all OSes for consistency
# Hardware Activation
EXISTING_CARDS=$(ls /dev/dri/card* 2>/dev/null)
IGPU_CARD=$(echo "$EXISTING_CARDS" | head -n 1)
ENABLE_PATH="/sys/devices/platform/asus-nb-wmi/egpu_enable"
if [ "$(cat $ENABLE_PATH)" -eq 0 ]; then
  echo 1 > "$ENABLE_PATH" || true
fi
echo 1 > /sys/bus/pci/rescan

sleep 2

if [[ "$OS_TYPE" == *"bazzite"* ]]; then
  if [ "$VENDOR" == "nvidia" ]; then
    echo "Loading NVIDIA drivers into kernel to generate DRM nodes..."
    systemctl enable nvidia-persistenced nvidia-powerd 2>/dev/null
    systemctl start nvidia-persistenced nvidia-powerd 2>/dev/null
    modprobe -r nvidia_drm nvidia_modeset nvidia_uvm nvidia 2>/dev/null || true
    modprobe nvidia_drm modeset=1 fbdev=1
    modprobe nvidia_modeset nvidia_uvm nvidia
  fi
fi

# Wait for Hardware
COUNT=0
EGPU_CARD=""
while [ -z "$EGPU_CARD" ] && [ $COUNT -lt 15 ]; do
  echo "Waiting for eGPU card... ($COUNT)"
  CURRENT_CARDS=$(ls /dev/dri/card* 2>/dev/null)
  for card in $CURRENT_CARDS; do
    if ! echo "$EXISTING_CARDS" | grep -q "$card"; then
      EGPU_CARD=$card
      break
    fi
  done
  [ -n "$EGPU_CARD" ] && break
  sleep 1
  ((COUNT++))
done

if [ -z "$EGPU_CARD" ]; then
  echo "ERROR: Hardware failed to appear in /dev/dri/"
  exit 5
fi
echo "Success! eGPU dynamically detected as: $EGPU_CARD"
# Permissions (The ACL Hero)
#echo "Setting user permissions for eGPU..."
echo "Setting permissions for user: $PRIMARY_USER"
setfacl -m u:$PRIMARY_USER:rw $EGPU_CARD
setfacl -m u:$PRIMARY_USER:rw /dev/dri/renderD*

if [ -e /dev/nvidiactl ]; then
  echo "Granting NVIDIA node permissions for overlay..."
  setfacl -m "u:$PRIMARY_USER:rw" /dev/nvidia*
fi

  # STOP UI
# We must stop sddm so we can unload the driver modules
echo "Stopping SDDM..."
systemctl stop sddm

 
if [[ "$OS_TYPE" == "steamos" || "$OS_TYPE" == *"cachyos"* ]]; then
# DRIVER RELOAD 
  if [ "$VENDOR" == "nvidia" ]; then
    echo "Detecting NVIDIA Hardware ID..."
    NVIDIA_ID=$(lspci -n -d 10de: | head -n 1 | awk '{print $3}')
  
    if [ -z "$NVIDIA_ID" ]; then
      echo "ERROR: Could not detect an NVIDIA GPU ID on the PCIe bus. Aborting."
      exit 6
    fi
    echo "Dynamic Hardware Lock: $NVIDIA_ID"

    echo "Re-fanging NVIDIA configs for active session..."
    steamos-readonly disable
    mv $DATA_DIR/configs_backup/10_nvidia* /usr/share/glvnd/egl_vendor.d/ 2>/dev/null || true
    mv $DATA_DIR/configs_backup/*icd* /usr/share/vulkan/icd.d/ 2>/dev/null || true
    mv $DATA_DIR/configs_backup/*layer* /usr/share/vulkan/implicit_layer.d/ 2>/dev/null || true
    mv $DATA_DIR/configs_backup/*layer* /usr/share/vulkan/explicit_layer.d/ 2>/dev/null || true
    mv $DATA_DIR/configs_backup/10-nvidia* /usr/share/X11/xorg.conf.d/ 2>/dev/null || true
    steamos-readonly enable

    # This is what forces the NVIDIA card into Wayland mode
    echo "Loading NVIDIA modules..."
    modprobe -r nvidia_drm nvidia_modeset nvidia_uvm nvidia
    modprobe nvidia_drm modeset=1 fbdev=1
    modprobe nvidia_modeset nvidia_uvm nvidia

    # PERSISTENT DRIVER SETTINGS
    # We write the modeset to a config file so the kernel loads it at boot
    echo "Setting NVIDIA config file for persistence on reboot..."
    echo "options nvidia_drm modeset=1 fbdev=1" > /etc/modprobe.d/nvidia-egpu.conf

    # PERSISTENT ENVIRONMENT (The Global File)
    # We use a function to safely add lines to /etc/environment
    echo "Writing environment variables to disk......"
    safe_add() {
      grep -qF "$1" /etc/environment || echo "$1" >> /etc/environment
    }

    safe_add "MESA_VK_DEVICE_SELECT=$NVIDIA_ID"
    safe_add "VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json"
    safe_add "WLR_DRM_DEVICES=$EGPU_CARD:$IGPU_CARD"
    #safe_add "KWIN_DRM_DEVICES=$EGPU_CARD:$IGPU_CARD"
    #safe_add "GBM_BACKEND=nvidia-drm"
    #safe_add "__GLX_VENDOR_LIBRARY_NAME=nvidia"
    safe_add "VK_LOADER_LAYERS_DISABLE=*"
    safe_add "GAMESCOPE_DISABLE_VK_KHR_PRESENT_WAIT=1"

    # Environment Injection (System-Wide)
    echo "Injecting variables into systemd session..."
    systemctl set-environment MESA_VK_DEVICE_SELECT=$NVIDIA_ID
    systemctl set-environment VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json
    systemctl set-environment WLR_DRM_DEVICES=$EGPU_CARD:$IGPU_CARD
    #systemctl set-environment KWIN_DRM_DEVICES=$EGPU_CARD:$IGPU_CARD
    #systemctl set-environment GBM_BACKEND=nvidia-drm
    #systemctl set-environment __GLX_VENDOR_LIBRARY_NAME=nvidia
    systemctl set-environment VK_LOADER_LAYERS_DISABLE="*"
    systemctl set-environment GAMESCOPE_DISABLE_VK_KHR_PRESENT_WAIT=1

    # Environment Injection (User-Session Fix)
    # We explicitly define the XDG_RUNTIME_DIR so root can talk to the deck session
    USER_UID=$(id -u $PRIMARY_USER)
    export DECK_BUS="XDG_RUNTIME_DIR=/run/user/$USER_UID"
    sudo -u $PRIMARY_USER $DECK_BUS systemctl --user set-environment MESA_VK_DEVICE_SELECT=$NVIDIA_ID
    sudo -u $PRIMARY_USER $DECK_BUS systemctl --user set-environment VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.json
    sudo -u $PRIMARY_USER $DECK_BUS systemctl --user set-environment WLR_DRM_DEVICES=$EGPU_CARD:$IGPU_CARD
    #sudo -u $PRIMARY_USER $DECK_BUS systemctl --user set-environment KWIN_DRM_DEVICES=$EGPU_CARD:$IGPU_CARD
    #sudo -u $PRIMARY_USER $DECK_BUS systemctl --user set-environment GBM_BACKEND=nvidia-drm
    #sudo -u $PRIMARY_USER $DECK_BUS systemctl --user set-environment __GLX_VENDOR_LIBRARY_NAME=nvidia

    echo "Creating isolated KDE Plasma environment config..."
    PLASMA_ENV_DIR="/home/$PRIMARY_USER/.config/plasma-workspace/env"
    sudo -u $PRIMARY_USER mkdir -p "$PLASMA_ENV_DIR"
  
    sudo -u $PRIMARY_USER bash -c "cat > '$PLASMA_ENV_DIR/xgmobile-nvidia-kwin.sh' << EOF
#!/bin/bash
export KWIN_DRM_DEVICES=$EGPU_CARD:$IGPU_CARD
export GBM_BACKEND=nvidia-drm
export __GLX_VENDOR_LIBRARY_NAME=nvidia
EOF"
    chmod +x "$PLASMA_ENV_DIR/xgmobile-nvidia-kwin.sh"

    # Final Reload & Start
    echo "Daemon-reload and start SDDM..."
    systemctl daemon-reload
    sudo -u $PRIMARY_USER $DECK_BUS systemctl --user daemon-reload

  elif [ "$VENDOR" == "amd" ]; then
    # AMD Lean Path (Assumes amdgpu driver handles it)
    echo "AMD Vendor detected. Refreshing DRM session..."
    # No extra variables usually needed for AMD eGPUs on SteamOS
  fi
fi
echo "Refreshing DRM session..."
systemctl start sddm --no-block

#if [ $SUPERGFX_TRIG == 1 ]; then
#  echo "Restarting supergfxctl..."
#  systemctl restart supergfxd.service 2>/dev/null || true
#fi
#This was too destructive for Flow Laptops
#if command -v supergfxctl >/dev/null 2>&1; then #[[ "$OS_TYPE" == *"bazzite"* || "$OS_TYPE" == "cachyos" ]]; then
#  echo "Supergfxctl Detected. Disabling so it does not interupt our boot..."
#  systemctl disable supergfxd.service 2>/dev/null || true
#fi

PRODUCT_NAME=$(cat /sys/class/dmi/id/product_name 2>/dev/null || echo "Unknown")

if command -v supergfxctl >/dev/null 2>&1; then
  if [[ "$PRODUCT_NAME" == *"RC71L"* || "$PRODUCT_NAME" == *"Ally"* ]]; then
    echo "Handheld Detected ($PRODUCT_NAME). Disabling supergfxd to prevent interference..."
    systemctl disable supergfxd.service 2>/dev/null || true
  elif [[ "$PRODUCT_NAME" == *"Flow"* || "$PRODUCT_NAME" == *"GV"* || "$PRODUCT_NAME" == *"GZ"* ]]; then
    echo "Flow Laptop Detected ($PRODUCT_NAME). Leaving supergfxd active for MUX control..."
    # You can add supergfxctl restart logic here if Flow laptops require it after the WMI switch
  else
    echo "Unknown ASUS device ($PRODUCT_NAME). Leaving supergfxd alone."
  fi
fi

echo "--- Enable Finished: Time for God Mode ---"
sudo ln -sf "$LOG_DIR/xgmobile_manager_enable_${VENDOR}.log" $LOG_DIR/xgmobile_manager_enable_latest.log
