#!/bin/bash
VENDOR=$1 # Capture 'nvidia' or 'amd' from the plugin
OS_TYPE=$2
SUPERGFX_TRIG=0
DECK_HOME=$(eval echo ~deck)
DATA_DIR="$DECK_HOME/homebrew/data/xgmobile-manager"
LOG_DIR="$DECK_HOME/homebrew/logs"
mkdir -p "$DATA_DIR/configs"
exec > "$LOG_DIR/xgmobile_manager_eject_${VENDOR}.log" 2>&1

echo "--- XG Mobile Eject ($VENDOR) Started at $(date) ---"

# --- SUPERGFXCTL NATIVE PATH --- not currently working reliably
#if systemctl is-active --quiet supergfxd.service; then #command -v supergfxctl >/dev/null 2>&1 && [[ "$OS_TYPE" == *"bazzite"* || "$OS_TYPE" == "cachyos" ]]; then
#  echo "Supergfxctl Detected. Queuing Integrated mode in supergfxctl..."

#  if supergfxctl -m Integrated; then
#    echo "supergfxctl hardware disconnect successful."
#    echo "Executing detached SDDM restart..."
    
#    # FORK: Detaches from Decky Loader safely
#    ( sleep 2 && systemctl restart sddm ) >/dev/null 2>&1 &
#    disown
#    #echo "Executing non-blocking SDDM restart to apply hardware switch..."
#    #systemctl restart sddm --no-block
  
#    echo "--- Eject Finished: Waiting for detached restart ---"
#    ln -sf "$LOG_DIR/xgmobile_manager_eject_${VENDOR}.log" "$LOG_DIR/xgmobile_manager_eject_latest.log"
#    exit 0
#  else
#    echo "WARNING: supergfxctl crashed or failed to respond."
#    echo "Falling back to universal WMI hardware deactivation..."
#  fi
#fi

if systemctl is-active --quiet supergfxd.service; then 
  echo "Supergfxd Detected. Stopping supergfxd to avoid panic during switch..."
  systemctl stop supergfxd.service 2>/dev/null || true
  SUPERGFX_TRIG=1
fi

# Stop UI
# We must kill the session before we pull the rug out from the hardware
echo "Stopping SDDM..."
systemctl stop sddm

if [ "$OS_TYPE" == "steamos" ]; then
  echo "Sanitizing /etc/environment..."
  sed -i '/MESA_VK_DEVICE_SELECT/d' /etc/environment
  sed -i '/VK_ICD_FILENAMES/d' /etc/environment
  sed -i '/WLR_DRM_DEVICES/d' /etc/environment
  sed -i '/VK_LOADER_LAYERS_DISABLE/d' /etc/environment
  sed -i '/GAMESCOPE_DISABLE_VK_KHR_PRESENT_WAIT/d' /etc/environment

  if [ "$VENDOR" == "nvidia" ]; then
    # De-Fanging Configs
    echo "De-fanging NVIDIA configs to protect AMD Handheld Mode..."
    steamos-readonly disable
    mkdir -p $DATA_DIR/configs_backup
    mv /usr/share/glvnd/egl_vendor.d/*nvidia* $DATA_DIR/configs_backup/ 2>/dev/null || true
    mv /usr/share/vulkan/implicit_layer.d/*nvidia* $DATA_DIR/configs_backup/ 2>/dev/null || true
    mv /usr/share/vulkan/explicit_layer.d/*nvidia* $DATA_DIR/configs_backup/ 2>/dev/null || true
    mv /usr/share/vulkan/icd.d/*nvidia* $DATA_DIR/configs_backup/ 2>/dev/null || true
    mv /usr/share/X11/xorg.conf.d/10-nvidia* $DATA_DIR/configs_backup/ 2>/dev/null || true
    steamos-readonly enable
  
    # Environment Cleanup (System-Wide)
    # We unset the exact variables we set in the enable script
    echo "Removing environment variables from volitile memory..."
    systemctl unset-environment MESA_VK_DEVICE_SELECT
    systemctl unset-environment VK_ICD_FILENAMES
    systemctl unset-environment WLR_DRM_DEVICES
    systemctl unset-environment VK_LOADER_LAYERS_DISABLE
    systemctl unset-environment GAMESCOPE_DISABLE_VK_KHR_PRESENT_WAIT

    # Environment Cleanup (User-Session)
    # Mirroring the Enable script's use of the deck user's session bus
    export DECK_BUS="XDG_RUNTIME_DIR=/run/user/1000"
    sudo -u deck $DECK_BUS systemctl --user unset-environment MESA_VK_DEVICE_SELECT
    sudo -u deck $DECK_BUS systemctl --user unset-environment VK_ICD_FILENAMES
    sudo -u deck $DECK_BUS systemctl --user unset-environment WLR_DRM_DEVICES

    # DISK CLEANUP
    echo "Removing environment variables from disk..."
    rm -f /etc/modprobe.d/nvidia-egpu.conf
 
    # Driver Purge
    # We kill any processes still holding the GPU and unload the modules
    echo "Stopping NVIDIA power services..."
    systemctl stop nvidia-powerd nvidia-persistenced 2>/dev/null || true
    
    echo "Force killing any lingering GPU processes and stopping NVIDIA services..."
    fuser -kv /dev/nvidia* >/dev/null 2>&1
    modprobe -r nvidia_drm || true
    modprobe -r nvidia_modeset || true
    modprobe -r nvidia_uvm || true
    modprobe -r nvidia || true
  fi
elif [[ "$OS_TYPE" == *"bazzite"* || "$OS_TYPE" == "cachyos" ]]; then
  if [ "$VENDOR" == "nvidia" ]; then
    echo "Stopping NVIDIA power services..."
    systemctl stop nvidia-powerd nvidia-persistenced 2>/dev/null || true
    
    echo "Force killing any lingering GPU processes and unloading NVIDIA modules..."
    fuser -kv /dev/nvidia* >/dev/null 2>&1 || true
    modprobe -r nvidia_drm || true
    modprobe -r nvidia_modeset || true
    modprobe -r nvidia_uvm || true
    modprobe -r nvidia || true
  fi
fi 

echo "Ensuring card is free..."
fuser -kv /dev/dri/card* >/dev/null 2>&1 || true 
systemctl daemon-reload
# Final Reload & Restore Handheld UI
if [ "$OS_TYPE" == "steamos" ]; then
  export DECK_BUS="XDG_RUNTIME_DIR=/run/user/1000"
  sudo -u deck $DECK_BUS systemctl --user daemon-reload
fi

# Hardware Deactivation
INITIAL_CARDS=$(ls /dev/dri/card* 2>/dev/null)
INITIAL_COUNT=$(echo "$INITIAL_CARDS" | wc -w)

echo "Current DRM cards before disconnect: $INITIAL_COUNT"

ENABLE_PATH="/sys/devices/platform/asus-nb-wmi/egpu_enable"
echo 0 > "$ENABLE_PATH" || true
echo 1 > /sys/bus/pci/rescan

COUNT=0
SUCCESS=0

while [ $COUNT -lt 15 ]; do
  CURRENT_COUNT=$(ls /dev/dri/card* 2>/dev/null | wc -w)
  
  if [ "$CURRENT_COUNT" -lt "$INITIAL_COUNT" ]; then
    echo "Success! DRM card count dropped to $CURRENT_COUNT. eGPU safely detached."
    SUCCESS=1
    break
  fi
  
  echo "Waiting for eGPU to drop from PCIe bus... ($COUNT)"
  sleep 1
  ((COUNT++))
done

if [ "$SUCCESS" -eq 0 ]; then
  echo "WARNING: Hardware did not seem to drop from /dev/dri/. Proceeding anyway to restore UI."
fi

if [[ "$OS_TYPE" == *"bazzite"* || "$OS_TYPE" == "cachyos" ]]; then
  if [ "$VENDOR" == "nvidia" ]; then
    echo "Cleaning up Bazzite Wake Hook..."
    systemctl disable egpu-resume.service 2>/dev/null || true
    rm -f /etc/systemd/system/egpu-resume.service
    systemctl daemon-reload
  fi
fi

systemctl start sddm --no-block

#Bazzite leaves this off by default in the deck images so lets just let the user re-enable if they need to
#if command -v supergfxctl >/dev/null 2>&1; then #[[ "$OS_TYPE" == *"bazzite"* || "$OS_TYPE" == "cachyos" ]]; then
  #echo "Restarting ASUS daemon to restore Power Profile UI controls..."
  #systemctl start supergfxd.service 2>/dev/null || true
  
  #echo "Executing detached SDDM restart..."
  #( sleep 2 && systemctl restart sddm ) >/dev/null 2>&1 &
  #disown
#fi 

echo "--- Eject Finished: Back to Handheld Mode ---"
ln -sf "$LOG_DIR/xgmobile_manager_eject_${VENDOR}.log" $LOG_DIR/xgmobile_manager_eject_latest.log
