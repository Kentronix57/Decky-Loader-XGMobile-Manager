#!/bin/bash
# Returns JSON formatted stats for the frontend

if lsmod | grep -q "nvidia"; then
    # Query NVIDIA via nvidia-smi (if installed) or sysfs
    TEMP=$(/usr/bin/nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits 2>/dev/null || echo "0")
    UTIL=$(/usr/bin/nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null || echo "0")
    VRAM=$(/usr/bin/nvidia-smi --query-gpu=memory.used --format=csv,noheader,nounits 2>/dev/null || echo "0")
    POWER=$(/usr/bin/nvidia-smi --query-gpu=power.draw --format=csv,noheader,nounits 2>/dev/null || echo "0")
    
    echo "{\"vendor\": \"nvidia\", \"temp\": \"$TEMP°C\", \"util\": \"$UTIL%\", \"vram\": \"${VRAM}MB\", \"power\": \"${POWER}W\"}"

elif lsmod | grep -q "amdgpu"; then
    # Query AMD via sysfs (Standard Linux paths)
    # Note: XG Mobile is usually card1, but we use a variable so it's easy to change
    CARD="card1"

    # 1. Temperature (Millidegrees Celsius -> Celsius)
    # Using 'head -n 1' prevents bash math errors if multiple hwmon files exist
    TEMP_INPUT=$(cat /sys/class/drm/$CARD/device/hwmon/hwmon*/temp1_input 2>/dev/null | head -n 1)
    TEMP_INPUT=${TEMP_INPUT:-0} # Fallback to 0 if empty
    TEMP=$((TEMP_INPUT / 1000))

    # 2. GPU Utilization (0-100 Direct Percentage)
    UTIL=$(cat /sys/class/drm/$CARD/device/gpu_busy_percent 2>/dev/null | head -n 1)
    UTIL=${UTIL:-0}

    # 3. VRAM Usage (Bytes -> Megabytes)
    VRAM_BYTES=$(cat /sys/class/drm/$CARD/device/mem_info_vram_used 2>/dev/null | head -n 1)
    VRAM_BYTES=${VRAM_BYTES:-0}
    VRAM=$((VRAM_BYTES / 1048576))

    # 4. Power Draw (Microwatts -> Watts)
    # We check average first, and fallback to input if average isn't exposed by the firmware
    POWER_UW=$(cat /sys/class/drm/$CARD/device/hwmon/hwmon*/power1_average 2>/dev/null | head -n 1)
    if [ -z "$POWER_UW" ]; then
        POWER_UW=$(cat /sys/class/drm/$CARD/device/hwmon/hwmon*/power1_input 2>/dev/null | head -n 1)
    fi
    POWER_UW=${POWER_UW:-0}
    POWER=$((POWER_UW / 1000000))
    
    echo "{\"vendor\": \"amd\", \"temp\": \"$TEMP°C\", \"util\": \"$UTIL%\", \"vram\": \"${VRAM}MB\", \"power\": \"${POWER}W\"}"
else
    echo "{\"vendor\": \"none\"}"
fi
